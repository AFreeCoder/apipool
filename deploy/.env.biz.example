# =============================================================================
# APIPool 企业版实例 - 环境变量配置
# =============================================================================
# 复制此文件为 .env.biz 并修改必要的值。
# 密码和密钥等敏感信息不要提交到版本控制。
#
# 前置条件:
#   主实例必须已启动且健康（PostgreSQL 和 Redis 由主实例管理）
#
# 使用方式:
#   cd /opt/sub2api/deploy
#   cp .env.biz.example .env.biz
#   # 编辑 .env.biz，填入实际值
#   docker compose -f docker-compose.biz.yml --env-file .env.biz up -d
# =============================================================================

# Docker Compose 项目名（用于卷名和容器名前缀）
COMPOSE_PROJECT_NAME=sub2api-biz

# --- 基础配置（与主实例 .env 保持一致） ---
# 主实例的 PostgreSQL 密码（必须与主实例 .env 中的 POSTGRES_PASSWORD 相同）
POSTGRES_PASSWORD=
# 主实例的 PostgreSQL 用户（必须与主实例 .env 中的 POSTGRES_USER 相同）
POSTGRES_USER=sub2api

# 主实例的 Redis 密码（如果主实例设置了密码，此处需一致）
REDIS_PASSWORD=

# --- 企业实例独立配置 ---
# 企业实例数据库名（独立于主实例）
BIZ_POSTGRES_DB=sub2api_biz

# 企业实例 Redis DB 编号（主实例用 0，企业实例用 1）
BIZ_REDIS_DB=1

# 企业实例管理员账号
BIZ_ADMIN_EMAIL=admin@biz.apipool.dev
BIZ_ADMIN_PASSWORD=

# 企业实例 JWT 密钥（必须与主实例不同！留空则自动生成）
BIZ_JWT_SECRET=
# 企业实例 TOTP 加密密钥（必须与主实例不同！留空则自动生成）
BIZ_TOTP_ENCRYPTION_KEY=

# --- 可选配置 ---
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai
UPDATE_PROXY_URL=
